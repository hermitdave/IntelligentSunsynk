# =============================================================================
# IntelligentSunsynk - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your credentials.
# NEVER commit your .env file to version control!

# =============================================================================
# SUNSYNK CLOUD API (Required)
# =============================================================================
# SunSynk account login credentials.
# Quote values containing special characters such as '#'.
SUNSYNK_USERNAME=your_email@example.com
SUNSYNK_PASSWORD="your_password_here"

# Optional workaround: paste a valid bearer token from the SunSynk web app.
# When set, this app will use it instead of the password grant above.
# SUNSYNK_ACCESS_TOKEN=eyJhbGciOi...

# Inverter serial number (visible on inverter label or SunSynk Connect app)
SUNSYNK_SERIAL=your_inverter_serial
# Plant ID
SUNSYNK_PLANT_ID=123456

# SSL verification (SunSynk recommends False for OpenAPI)
SUNSYNK_VERIFY_SSL=false

# =============================================================================
# OCTOPUS ENERGY (Required for Intelligent Go dispatch slots)
# =============================================================================
# Get your API key from: https://octopus.energy/dashboard/developer/
OCTOPUS_API_KEY=sk_live_your_key_here
OCTOPUS_ACCOUNT_ID=A-XXXXXXXX

# =============================================================================
# WEB SERVER
# =============================================================================
WEB_HOST=0.0.0.0
WEB_PORT=8080

# Cron schedule for charge slot checks (default: every 5 minutes)
CRON_SCHEDULE=*/5 * * * *

# Time-of-day battery SoC thresholds for grid charging while in a dispatch slot.
# Format: "HH:MM=NN,..." (local time). Each threshold applies until the next
# entry; the last entry wraps past midnight. Grid charging (peakAndVallery=0)
# engages only while SoC is below the current threshold.
SOC_THRESHOLD_SCHEDULE="09:00=90,12:00=75,15:00=60,18:00=45"

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
