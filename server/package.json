{
  "name": "intelligent-sunsynk-server",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "main": "dist/index.js",
  "scripts": {
    "prestart": "node ../scripts/check-node-version.cjs",
    "start": "ts-node-dev --respawn --transpile-only src/index.ts",
    "prebuild": "node ../scripts/check-node-version.cjs",
    "build": "tsc",
    "preserve": "node ../scripts/check-node-version.cjs",
    "serve": "node dist/index.js",
    "pretest": "node ../scripts/check-node-version.cjs",
    "test": "jest --forceExit"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.9",
    "@types/node-cron": "^3.0.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ]
  }
}
